{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://owntology.local/schemas/ontology.schema.json",
  "title": "owntology entity frontmatter schema",
  "description": "노트 frontmatter의 엔티티 타입별 계약. 위원회 P1-1: 엔티티 종류·식별자·관계를 명시화한다. validate_ontology.py 가 이 스키마로 people/projects 노트를 검증한다.",
  "type": "object",
  "required": ["type", "entity_id"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["person", "group", "project", "organization", "account", "event", "conversation", "note", "decision", "preference", "index", "blog", "daily", "link", "link_batch", "catalog_update"],
      "description": "엔티티 종류. 기계가 읽는 타입과 본문 설명이 일치해야 한다(예: 가족 그룹은 person이 아니라 group)."
    },
    "entity_id": {
      "type": "string",
      "pattern": "^[a-z]+:[a-z0-9가-힣._-]+$",
      "description": "불변 고유 식별자. 형식 '<type>:<slug>' (예: person:son-myeongji, group:fam). 병합·표기변경에도 유지."
    },
    "name": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "canonical": { "type": "boolean", "description": "동일 엔티티가 여럿이면 정확히 하나만 true." },
    "merged_from": { "type": "array", "items": { "type": "string" }, "description": "이 노트로 병합된 이전 노트 경로/entity_id." },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "private", "sensitive", "secret"],
      "description": "검색/조회 접근통제 등급. sensitive·secret은 기본 차단(security.py)."
    },
    "relations": {
      "type": "array",
      "description": "관계는 본문 자연어가 아니라 구조화 필드로 저장(P1-3).",
      "items": {
        "type": "object",
        "required": ["subject", "relation", "object"],
        "properties": {
          "subject": { "type": "string", "description": "주체 entity_id 또는 name" },
          "relation": { "type": "string", "description": "관계 종류(방향 있음). 예: father_of, mother_of, younger_sister_of, member_of, works_at" },
          "object": { "type": "string", "description": "대상 entity_id 또는 name" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "valid_from": { "type": "string", "format": "date" },
          "valid_to": { "type": ["string", "null"], "format": "date" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "source_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "이 노트의 근거가 된 원문 식별자(P1-5). 증거사슬 추적용."
    },
    "valid_from": { "type": ["string", "null"], "format": "date", "description": "사실 유효 시작일." },
    "valid_to": { "type": ["string", "null"], "format": "date", "description": "사실 유효 종료일(현재 유효=null)." },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "extraction": {
      "type": "string",
      "enum": ["auto", "confirmed"],
      "description": "auto=자동추출(미검증), confirmed=사용자 확인."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "group" } } },
      "then": { "required": ["entity_id", "name"], "properties": { "members": { "type": "array", "items": { "type": "string" } } } }
    },
    {
      "if": { "properties": { "type": { "const": "account" } } },
      "then": { "description": "계정 엔티티는 비밀값을 본문에 두지 않는다. sensitivity는 secret 권장.", "properties": { "sensitivity": { "const": "secret" } } }
    }
  ]
}
